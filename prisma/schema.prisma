generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  ADMIN
  PROPRIETARIO
  STORE_MANAGER
  STAFF
}

enum ReservationStatus {
  IN_ATTESA
  CONFERMATA
  IN_CORSO
  COMPLETATA
  CANCELLATA
  NO_SHOW
}

enum ReservationSource {
  PUBBLICA
  ADMIN
  TELEFONO
  WALK_IN
  WAITLIST
}

enum WaitlistStatus {
  OPEN
  CONVERTED
  CLOSED
}

enum NotificationDeliveryMode {
  SMS
  EMAIL
  BOTH
}

enum NotificationChannel {
  SMS
  EMAIL
  INTERNAL
  WEBHOOK
}

enum NotificationLogStatus {
  SENT
  FAILED
  SKIPPED
}

enum NotificationJobStatus {
  PENDING
  PROCESSING
  RETRYING
  COMPLETED
  FAILED
  CANCELLED
}

enum TableSessionStatus {
  OPEN
  PAYMENT_REQUESTED
  PAID
  CLOSED
}

enum TableLayoutShape {
  RECT
  ROUND
}

enum CustomerScoreBand {
  A
  B
  C
  D
}

enum PaymentRequestStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  EXPIRED
}

enum BackupSnapshotKind {
  CONFIG
  FULL
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  passwordHash   String
  role           UserRole
  active         Boolean        @default(true)
  archivedAt     DateTime?
  archiveReason  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  sessions       Session[]
  locationAccess UserLocation[]
  auditLogs      AuditLog[]
  notificationReads AdminNotificationRead[]
  savedFilters   SavedFilter[]
  backups        BackupSnapshot[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Location {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  address             String
  city                String
  phone               String?
  email               String?
  reservationEnabled  Boolean              @default(true)
  archivedAt          DateTime?
  archiveReason       String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  openingHours        OpeningHour[]
  openingExceptions   OpeningHourException[]
  zones               LocationZone[]
  tables              DiningTable[]
  menus               Menu[]
  reservations        Reservation[]
  settings            ReservationSetting?
  technicalSettings   LocationTechnicalSetting?
  tableSessions       TableSession[]
  userAssignments     UserLocation[]
  waitlistEntries     WaitlistEntry[]
  notificationLogs    NotificationLog[]
  notificationJobs    NotificationJob[]
  adminNotifications  AdminNotification[]
  auditLogs           AuditLog[]
  savedFilters        SavedFilter[]
  backups             BackupSnapshot[]
  paymentRequests     PaymentRequest[]
  posTransactions     PosTransaction[]
}

model RolePermission {
  id                     String    @id @default(cuid())
  role                   UserRole  @unique
  canViewDashboard       Boolean   @default(true)
  canViewLocations       Boolean   @default(false)
  canManageLocations     Boolean   @default(false)
  canViewTables          Boolean   @default(false)
  canManageTables        Boolean   @default(false)
  canDeleteTables        Boolean   @default(false)
  canViewMenus           Boolean   @default(false)
  canManageMenus         Boolean   @default(false)
  canViewHours           Boolean   @default(false)
  canManageHours         Boolean   @default(false)
  canViewReservations    Boolean   @default(false)
  canManageReservations  Boolean   @default(false)
  canViewUsers           Boolean   @default(false)
  canManageUsers         Boolean   @default(false)
  canViewConsoleAdmin    Boolean   @default(false)
  canManageConsoleAdmin  Boolean   @default(false)
  useHandheldMode        Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model LocationTechnicalSetting {
  id                      String    @id @default(cuid())
  locationId              String    @unique
  displayName             String?
  qrEnabled               Boolean   @default(false)
  reservationsEnabled     Boolean   @default(true)
  yieldEngineEnabled      Boolean   @default(false)
  slotOptimizationEnabled Boolean   @default(true)
  smartWaitlistEnabled    Boolean   @default(true)
  customerScoringEnabled  Boolean   @default(true)
  tableAssignmentStrategy String    @default("BALANCED")
  tableAssignmentSlotMode String    @default("FLEXIBLE")
  tableAssignmentFlexMinutes Int    @default(30)
  tableAssignmentTurnoverBufferMinutes Int @default(15)
  tableAssignmentCombineTablesEnabled Boolean @default(true)
  tableAssignmentMaxTables Int      @default(4)
  tableAssignmentMinOccupancyPercent Int @default(50)
  tableAssignmentWeightTableFit Int @default(30)
  tableAssignmentWeightPartySize Int @default(25)
  tableAssignmentWeightCustomerPriority Int @default(20)
  tableAssignmentWeightAverageSpend Int @default(15)
  tableAssignmentWeightCreatedAt Int @default(10)
  predictiveDurationEnabled Boolean @default(true)
  kitchenLoadGuardEnabled Boolean @default(true)
  kitchenLoadWindowMinutes Int @default(30)
  kitchenLoadMaxCovers Int @default(40)
  controlledOverbookingEnabled Boolean @default(false)
  controlledOverbookingMaxCovers Int @default(0)
  controlledOverbookingMinReliabilityScore Int @default(70)
  waitlistOfferTtlMinutes Int @default(8)
  ownerBriefEnabled      Boolean   @default(true)
  ownerBriefMorningHour  Int       @default(10)
  yieldRuleSettings      Json?
  adaptiveDepositEnabled  Boolean   @default(false)
  adaptiveDepositAmount   Decimal?  @db.Decimal(10, 2)
  customerTableSelectionEnabled Boolean @default(false)
  deliveryEnabled         Boolean   @default(false)
  paymentsEnabled         Boolean   @default(false)
  notificationWebhookEnabled Boolean @default(false)
  notificationWebhookUrl  String?
  notificationWebhookSecret String?
  posEnabled              Boolean   @default(false)
  posProvider             String?
  posApiBaseUrl           String?
  posApiKey               String?
  posWebhookSecret        String?
  googleBusinessEnabled   Boolean   @default(false)
  reservationEmails       String?
  deliveryProvider        String?
  deliveryApiBaseUrl      String?
  deliveryApiKey          String?
  deliveryWebhookSecret   String?
  googleBusinessPlaceId   String?
  googleBusinessAccountId String?
  googleBusinessLocationId String?
  googleBusinessApiKey    String?
  paymentProvider         String?
  paymentPublicKey        String?
  paymentApiKey           String?
  paymentWebhookSecret    String?
  paymentCheckoutBaseUrl  String?
  smsEnabled              Boolean   @default(false)
  smsAlias                String?
  smsUsername             String?
  smsPassword             String?
  reservationStatusSmsStatuses String[] @default([])
  reservationStatusSmsTemplate String?
  waitlistSmsTemplate     String?
  manageLinkDeliveryMode  NotificationDeliveryMode @default(SMS)
  manageLinkSmsTemplate   String?
  manageLinkEmailSubject  String?
  manageLinkEmailTemplate String?
  smtpHost                String?
  smtpPort                Int?
  smtpSecure              Boolean   @default(false)
  smtpUsername            String?
  smtpPassword            String?
  smtpFromName            String?
  smtpFromEmail           String?
  crmReminderLeadHours    Int       @default(24)
  crmBirthdayEnabled      Boolean   @default(false)
  crmBirthdayTemplate     String?
  crmVipReminderEnabled   Boolean   @default(false)
  crmVipReminderTemplate  String?
  crmRiskReminderEnabled  Boolean   @default(false)
  crmRiskReminderTemplate String?
  crmNoShowReminderEnabled Boolean  @default(false)
  crmNoShowReminderTemplate String?
  technicalNotes          String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  location                Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model UserLocation {
  id         String   @id @default(cuid())
  userId     String
  locationId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
}

model OpeningHour {
  id         String   @id @default(cuid())
  locationId String
  weekday    Int
  opensAt    String
  closesAt   String
  isClosed   Boolean  @default(false)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, weekday])
}

model OpeningHourException {
  id         String   @id @default(cuid())
  locationId String
  date       DateTime
  opensAt    String?
  closesAt   String?
  isClosed   Boolean  @default(false)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, date])
}

model LocationZone {
  id         String       @id @default(cuid())
  locationId String
  name       String
  sortOrder  Int          @default(0)
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  location   Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  tables     DiningTable[]

  @@unique([locationId, name])
}

model DiningTable {
  id           String        @id @default(cuid())
  locationId   String
  zoneId       String?
  code         String
  seats        Int
  zone         String?
  layoutX      Int?
  layoutY      Int?
  layoutWidth  Int?
  layoutHeight Int?
  layoutRotation Int?
  layoutShape  TableLayoutShape @default(RECT)
  combinableWithIds String[] @default([])
  active       Boolean       @default(true)
  archivedAt   DateTime?
  archiveReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  location     Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  zoneRecord   LocationZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  reservations Reservation[]
  sessions     TableSession[]

  @@unique([locationId, code])
}

model Menu {
  id                    String        @id @default(cuid())
  locationId            String
  name                  String
  description           String?
  isActive              Boolean       @default(true)
  deliveryEnabled       Boolean       @default(false)
  appliesToAllLocations Boolean       @default(false)
  locationIds           String[]      @default([])
  archivedAt            DateTime?
  archiveReason         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  location              Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sections              MenuSection[]
}

model MenuSection {
  id        String     @id @default(cuid())
  menuId     String
  name      String
  sortOrder Int        @default(0)
  menu       Menu      @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items      MenuItem[]
}

model MenuItem {
  id           String             @id @default(cuid())
  sectionId    String
  name         String
  description  String?
  imageUrl     String?
  price        Decimal            @db.Decimal(10, 2)
  allergens    String?
  available    Boolean            @default(true)
  sortOrder    Int                @default(0)
  section      MenuSection        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sessionItems TableSessionItem[]
}

model CustomerProfile {
  id                    String            @id @default(cuid())
  displayName           String
  normalizedEmail       String?           @unique
  normalizedPhone       String?           @unique
  vip                   Boolean           @default(false)
  birthDate             DateTime?
  tags                  String[]          @default([])
  notes                 String?
  firstSeenAt           DateTime          @default(now())
  lastReservationAt     DateTime?
  lastCompletedAt       DateTime?
  visitCount            Int               @default(0)
  completedReservations Int               @default(0)
  cancelledReservations Int               @default(0)
  noShowCount           Int               @default(0)
  waitlistCount         Int               @default(0)
  totalSpend            Decimal           @default(0) @db.Decimal(10, 2)
  averageSpend          Decimal           @default(0) @db.Decimal(10, 2)
  frequencyScore        Int               @default(0)
  reliabilityScore      Int               @default(0)
  valueScore            Int               @default(0)
  priorityScore         Int               @default(0)
  band                  CustomerScoreBand @default(B)
  archivedAt            DateTime?
  archiveReason         String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  reservations          Reservation[]
  waitlistEntries       WaitlistEntry[]
  notificationJobs      NotificationJob[]
  paymentRequests       PaymentRequest[]
  posTransactions       PosTransaction[]

  @@index([band, priorityScore])
  @@index([lastReservationAt])
}

model ReservationSetting {
  id                 String   @id @default(cuid())
  locationId         String   @unique
  pageTitle          String?
  welcomeMessage     String?
  durationMinutes    Int      @default(120)
  useTimeSlots       Boolean  @default(true)
  slotIntervalMinutes Int     @default(30)
  leadTimeMinutes    Int      @default(60)
  minGuests          Int      @default(1)
  maxGuests          Int      @default(8)
  requirePhone       Boolean  @default(true)
  requireEmail       Boolean  @default(true)
  location           Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model Reservation {
  id          String            @id @default(cuid())
  locationId  String
  tableId     String?
  tableIds    String[]          @default([])
  customerProfileId String?
  manageToken String?           @unique
  guestName   String
  guestEmail  String?
  guestPhone  String?
  guests      Int
  dateTime    DateTime
  notes       String?
  spendAmount Decimal?          @db.Decimal(10, 2)
  customerBand CustomerScoreBand?
  customerPriorityScore Int     @default(0)
  depositRequired Boolean       @default(false)
  depositAmount Decimal?        @db.Decimal(10, 2)
  status      ReservationStatus @default(IN_ATTESA)
  source      ReservationSource @default(PUBBLICA)
  archivedAt  DateTime?
  archiveReason String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  location    Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  table       DiningTable?      @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customerProfile CustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  waitlistEntries WaitlistEntry[]
  notificationLogs NotificationLog[]
  notificationJobs NotificationJob[]
  adminNotifications AdminNotification[]
  auditLogs   AuditLog[]
  paymentRequests PaymentRequest[]
  posTransactions PosTransaction[]
}

model WaitlistEntry {
  id                String         @id @default(cuid())
  locationId        String
  reservationId     String?
  customerProfileId String?
  guestName         String
  guestEmail        String?
  guestPhone        String?
  guests            Int
  preferredDateTime DateTime
  notes             String?
  customerBand      CustomerScoreBand?
  priorityScore     Int            @default(0)
  status            WaitlistStatus @default(OPEN)
  notifiedAt        DateTime?
  archivedAt        DateTime?
  archiveReason     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  location          Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  reservation       Reservation?   @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  customerProfile   CustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  notificationLogs  NotificationLog[]
  notificationJobs  NotificationJob[]
  adminNotifications AdminNotification[]
}

model NotificationLog {
  id             String                @id @default(cuid())
  jobId          String?
  locationId     String
  reservationId  String?
  waitlistEntryId String?
  channel        NotificationChannel
  status         NotificationLogStatus @default(SENT)
  event          String
  attemptNumber  Int                   @default(1)
  destination    String?
  subject        String?
  contentPreview String?
  providerResponse String?
  errorMessage   String?
  createdAt      DateTime              @default(now())
  job            NotificationJob?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  location       Location              @relation(fields: [locationId], references: [id], onDelete: Cascade)
  reservation    Reservation?          @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  waitlistEntry  WaitlistEntry?        @relation(fields: [waitlistEntryId], references: [id], onDelete: SetNull)
}

model NotificationJob {
  id               String                @id @default(cuid())
  locationId       String?
  reservationId    String?
  waitlistEntryId  String?
  customerProfileId String?
  paymentRequestId String?
  channel          NotificationChannel
  event            String
  destination      String?
  subject          String?
  content          String?
  payload          Json?
  status           NotificationJobStatus @default(PENDING)
  attempts         Int                   @default(0)
  maxAttempts      Int                   @default(3)
  nextAttemptAt    DateTime              @default(now())
  lastAttemptAt    DateTime?
  completedAt      DateTime?
  lastError        String?
  providerResponse String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  logs             NotificationLog[]
  location         Location?             @relation(fields: [locationId], references: [id], onDelete: SetNull)
  reservation      Reservation?          @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  waitlistEntry    WaitlistEntry?        @relation(fields: [waitlistEntryId], references: [id], onDelete: SetNull)
  customerProfile  CustomerProfile?      @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  paymentRequest   PaymentRequest?       @relation(fields: [paymentRequestId], references: [id], onDelete: SetNull)

  @@index([status, nextAttemptAt])
  @@index([locationId, event, status])
}

model AuditLog {
  id            String    @id @default(cuid())
  locationId    String?
  reservationId String?
  userId        String?
  entityType    String
  entityId      String
  action        String
  summary       String
  metadata      Json?
  createdAt     DateTime  @default(now())
  location      Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model SavedFilter {
  id         String    @id @default(cuid())
  userId     String?
  role       UserRole?
  pageKey    String
  name       String
  locationId String?
  filters    Json
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([pageKey, role, locationId])
  @@index([userId, pageKey])
}

model BackupSnapshot {
  id          String             @id @default(cuid())
  locationId  String?
  createdById String?
  kind        BackupSnapshotKind @default(CONFIG)
  name        String
  notes       String?
  payload     Json
  createdAt   DateTime           @default(now())
  location    Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdBy   User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([locationId, createdAt])
}

model PaymentRequest {
  id                String               @id @default(cuid())
  token             String               @unique @default(cuid())
  locationId        String
  reservationId     String?
  customerProfileId String?
  provider          String?
  externalReference String?
  amount            Decimal              @db.Decimal(10, 2)
  currency          String               @default("EUR")
  status            PaymentRequestStatus @default(PENDING)
  checkoutUrl       String?
  paidAt            DateTime?
  expiresAt         DateTime?
  rawPayload        Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  location          Location             @relation(fields: [locationId], references: [id], onDelete: Cascade)
  reservation       Reservation?         @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  customerProfile   CustomerProfile?     @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  notificationJobs  NotificationJob[]

  @@index([locationId, status])
  @@index([reservationId, status])
  @@unique([locationId, externalReference])
}

model PosTransaction {
  id                String           @id @default(cuid())
  locationId        String
  reservationId     String?
  customerProfileId String?
  source            String           @default("WEBHOOK")
  provider          String?
  externalId        String
  totalAmount       Decimal          @db.Decimal(10, 2)
  guests            Int?
  occurredAt        DateTime
  payload           Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  location          Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  reservation       Reservation?     @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  customerProfile   CustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)

  @@unique([locationId, externalId])
  @@index([occurredAt])
}

model TableSession {
  id                 String             @id @default(cuid())
  token              String             @unique @default(cuid())
  locationId         String
  tableId            String
  status             TableSessionStatus @default(OPEN)
  paymentRequestedAt DateTime?
  paidAt             DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  location           Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  table              DiningTable        @relation(fields: [tableId], references: [id], onDelete: Cascade)
  seats              TableSessionSeat[]
  items              TableSessionItem[]
  adminNotifications AdminNotification[]

  @@index([tableId, status])
}

model AdminNotification {
  id              String                  @id @default(cuid())
  locationId      String?
  reservationId   String?
  waitlistEntryId String?
  sessionId       String?
  type            String
  title           String
  body            String
  href            String?
  targetRoles     UserRole[]              @default([])
  metadata        Json?
  createdAt       DateTime                @default(now())
  location        Location?               @relation(fields: [locationId], references: [id], onDelete: SetNull)
  reservation     Reservation?            @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  waitlistEntry   WaitlistEntry?          @relation(fields: [waitlistEntryId], references: [id], onDelete: SetNull)
  session         TableSession?           @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  reads           AdminNotificationRead[]

  @@index([createdAt])
  @@index([locationId, createdAt])
}

model AdminNotificationRead {
  id             String            @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime          @default(now())
  notification   AdminNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
}

model TableSessionSeat {
  id        String             @id @default(cuid())
  sessionId String
  code      String
  label     String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  session   TableSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  items     TableSessionItem[]

  @@unique([sessionId, code])
}

model TableSessionItem {
  id         String           @id @default(cuid())
  sessionId  String
  seatId     String?
  menuItemId String?
  name       String
  unitPrice  Decimal          @db.Decimal(10, 2)
  quantity   Int              @default(1)
  note       String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  session    TableSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  seat       TableSessionSeat? @relation(fields: [seatId], references: [id], onDelete: SetNull)
  menuItem   MenuItem?        @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
}
